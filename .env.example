# Copy to .env and fill in local values.
# Keep secrets out of version control.

APP_ENV=development
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# Optional multi-provider AI reasoning layer for the Investigation Engine.
# Providers are tried in LLM_PROVIDER_ORDER and the first configured one that
# answers wins. Leave every key unset to run fully offline with the deterministic
# reasoning composer (no external calls, no cost). Any configured provider is used
# only to *phrase* conclusions already proven from the investigation evidence.
LLM_PROVIDER_ORDER=anthropic,openrouter,openai,gemini
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30

# 1) Anthropic (official SDK)
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# 2) OpenRouter (OpenAI-compatible)
# OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 3) OpenAI (OpenAI-compatible)
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# 4) Google Gemini (Generative Language REST)
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
